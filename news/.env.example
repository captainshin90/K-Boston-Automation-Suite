# K-Boston News & Video Discovery – Environment Variables
# Copy to .env and fill in. Never commit this file.

# ── Required ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── News sources ──────────────────────────────────────────────────────
# NewsAPI: newsapi.org → Get API Key (free: 100 req/day)
NEWSAPI_KEY=

# SerpAPI: serpapi.com → Dashboard (100 free searches/month)
SERPAPI_KEY=

# YouTube: console.developers.google.com → Enable YouTube Data API v3
# Free: 10,000 units/day (a search costs 100 units)
YOUTUBE_API_KEY=

# ── WordPress ─────────────────────────────────────────────────────────
WP_SITE_URL=https://k-boston.org
WP_USERNAME=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WP_POST_STATUS=publish          # or: draft
WP_NEWS_CATEGORY=news
WP_VIDEO_CATEGORY=korean-videos
SKIP_DUPLICATES=true

# ── Behavior ──────────────────────────────────────────────────────────
DAYS_BACK=3                     # how many days back to pull news
RELEVANCE_THRESHOLD=45          # AI score cutoff (0-100)
MAX_ARTICLES=50
MAX_VIDEOS=30
OUTPUT_DIR=output
