# K-Boston Event Discovery – Environment Variables
# Copy this to .env and fill in your values
# Never commit .env to version control!

# ── Required ──────────────────────────────────────────────────────────
# Anthropic (Claude AI) – get at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Event Sources (at least one recommended) ──────────────────────────
# Eventbrite: eventbrite.com/account-settings/apps → Private Token
EVENTBRITE_TOKEN=

# Ticketmaster: developer.ticketmaster.com → Create App → API Key
TICKETMASTER_KEY=

# SerpAPI: serpapi.com → Dashboard → API Key (100 free searches/month)
SERPAPI_KEY=

# ── WordPress Import ──────────────────────────────────────────────────
# REST API (recommended)
WP_SITE_URL=https://k-boston.org
WP_USERNAME=admin
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx   # from Users → App Passwords

# FTP fallback (Hostinger)
FTP_HOST=ftp.k-boston.org
FTP_USER=
FTP_PASS=
FTP_REMOTE_PATH=/public_html/wp-content/uploads/tec-import/k-boston-events-latest.csv

# ── Behavior (optional) ───────────────────────────────────────────────
DAYS_AHEAD=60
RELEVANCE_THRESHOLD=40
OUTPUT_DIR=output
